#!/bin/sh
# Regenerate AUTO sections in README.md files and stage any changes so the
# regenerated content lands in the same commit as the code change that
# triggered the drift. Install via scripts/install-git-hooks.sh.

set -e

repo_root=$(git rev-parse --show-toplevel)

# Syntax-check staged Groovy files (CONVERSION-phase parse only — catches brace/
# quote/expression errors, not types or runtime). Skipped gracefully when Groovy
# isn't installed, so commits still work on machines without it.
if command -v groovy >/dev/null 2>&1; then
    staged_groovy=$(git -C "$repo_root" diff --cached --name-only --diff-filter=ACM -- '*.groovy')
    if [ -n "$staged_groovy" ]; then
        # shellcheck disable=SC2086
        ( cd "$repo_root" && groovy scripts/groovy-parse-check.groovy $staged_groovy )
    fi
fi

python3 "$repo_root/scripts/readme-sync.py" >/dev/null

# Stage any README.md the generator just rewrote. `git diff --name-only`
# without arguments lists unstaged changes against the index — exactly the
# files readme-sync.py just modified.
changed=$(git -C "$repo_root" diff --name-only -- '*README.md' ':!**/.git/**')
if [ -n "$changed" ]; then
    # shellcheck disable=SC2086
    git -C "$repo_root" add -- $changed
fi
