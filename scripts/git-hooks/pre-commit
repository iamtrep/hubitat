#!/bin/sh
# Regenerate AUTO sections in README.md files and stage any changes so the
# regenerated content lands in the same commit as the code change that
# triggered the drift. Install via scripts/install-git-hooks.sh.

set -e

repo_root=$(git rev-parse --show-toplevel)

python3 "$repo_root/scripts/readme-sync.py" >/dev/null

# Stage any README.md the generator just rewrote. `git diff --name-only`
# without arguments lists unstaged changes against the index — exactly the
# files readme-sync.py just modified.
changed=$(git -C "$repo_root" diff --name-only -- '*README.md' ':!**/.git/**')
if [ -n "$changed" ]; then
    # shellcheck disable=SC2086
    git -C "$repo_root" add -- $changed
fi
